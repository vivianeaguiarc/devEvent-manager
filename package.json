{
  "name": "devEvent-manager",
  "version": "1.0.0",
  "description": "Portfolio project focused on initialization, code quality and scalable architecture.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "node --watch src/index.js",
    "build": "pnpm clean && tsc",
    "start": "node dist/main/index.js",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "fix": "pnpm lint:fix && pnpm format",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm build",
    "prisma:generate": "pnpm prisma generate",
    "prisma:studio": "pnpm prisma studio",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "Viviane Aguiar",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "10.0.1",
    "@types/node": "25.5.0",
    "@types/pg": "^8.20.0",
    "eslint": "^9.39.4",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "husky": "9.1.7",
    "lint-staged": "16.3.3",
    "prettier": "3.8.1",
    "prisma": "^7.5.0",
    "rimraf": "^6.1.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0"
  }
}
